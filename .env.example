# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/freemarketwatch

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# CoinGecko API key — optional, increases rate limits on free tier
# Leave blank to use the unauthenticated free tier (10-30 req/min)
COINGECKO_API_KEY=

# Express server port
PORT=3333

NODE_ENV=development

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Used only by scripts/create-admin.ts — not read at runtime
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your_admin_password_here
